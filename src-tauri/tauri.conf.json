{
  "productName": "haex-space",
  "version": "0.1.0",
  "identifier": "space.haex",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://0.0.0.0:3333",
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm generate"
  },
  "app": {
    "windows": [
      {
        "title": "Haex Space",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },

  "plugins": {},
  "bundle": {
    "active": true,
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    },
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    },

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
